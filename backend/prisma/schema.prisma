generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED

  @@map("user_status")
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("template_status")
}

enum TemplatePageFormat {
  A4
  LETTER
  LEGAL
  CUSTOM

  @@map("template_page_format")
}

enum PageOrientation {
  PORTRAIT
  LANDSCAPE

  @@map("page_orientation")
}

enum TemplateSourceMode {
  BLANK
  BASE_PDF

  @@map("template_source_mode")
}

enum ApiCredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@map("api_credential_status")
}

model UserAccount {
  id                        String            @id @default(cuid())
  email                     String            @unique
  passwordHash              String            @map("password_hash")
  displayName               String            @map("display_name")
  avatarUrl                 String?           @map("avatar_url")
  status                    UserStatus        @default(ACTIVE)
  isSuperAdmin              Boolean           @default(false) @map("is_super_admin")
  tokenVersion              Int               @default(0) @map("token_version")
  lastLoginAt               DateTime?         @map("last_login_at")
  roles                     UserAccountRole[]
  createdTemplates          Template[]        @relation("TemplateCreatedBy")
  createdTemplateVersions   TemplateVersion[] @relation("TemplateVersionCreatedBy")
  publishedTemplateVersions TemplateVersion[] @relation("TemplateVersionPublishedBy")
  createdApiCredentials     ApiCredential[]   @relation("ApiCredentialCreatedBy")
  revokedApiCredentials     ApiCredential[]   @relation("ApiCredentialRevokedBy")
  auditEvents               AuditEvent[]      @relation("AuditActor")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  @@map("user_account")
}

model AccessRole {
  id          String                 @id @default(cuid())
  code        String                 @unique
  name        String
  description String?
  isSystem    Boolean                @default(false) @map("is_system")
  status      Boolean                @default(true)
  users       UserAccountRole[]
  permissions AccessRolePermission[]
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("access_role")
}

model AccessPermission {
  id          String                 @id @default(cuid())
  code        String                 @unique
  name        String
  category    String
  description String?
  status      Boolean                @default(true)
  roles       AccessRolePermission[]
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("access_permission")
}

model UserAccountRole {
  userAccountId String   @map("user_account_id")
  accessRoleId  String   @map("access_role_id")
  assignedAt    DateTime @default(now()) @map("assigned_at")

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  accessRole  AccessRole  @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)

  @@id([userAccountId, accessRoleId])
  @@map("user_account_role")
}

model AccessRolePermission {
  accessRoleId       String @map("access_role_id")
  accessPermissionId String @map("access_permission_id")

  accessRole       AccessRole       @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)
  accessPermission AccessPermission @relation(fields: [accessPermissionId], references: [id], onDelete: Cascade)

  @@id([accessRoleId, accessPermissionId])
  @@map("access_role_permission")
}

model ApiCredential {
  id             String              @id @default(cuid())
  name           String
  prefix         String              @unique
  secretPreview  String              @map("secret_preview")
  keyHash        String              @map("key_hash")
  status         ApiCredentialStatus @default(ACTIVE)
  allowedOrigins Json?               @map("allowed_origins")
  expiresAt      DateTime?           @map("expires_at")
  lastUsedAt     DateTime?           @map("last_used_at")
  lastUsedIp     String?             @map("last_used_ip")
  createdById    String?             @map("created_by_id")
  revokedById    String?             @map("revoked_by_id")
  revokedAt      DateTime?           @map("revoked_at")
  createdBy      UserAccount?        @relation("ApiCredentialCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  revokedBy      UserAccount?        @relation("ApiCredentialRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)
  auditEvents    AuditEvent[]        @relation("AuditApiCredential")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([status])
  @@map("api_credential")
}

model Template {
  id              String            @id @default(cuid())
  name            String
  code            String            @unique
  description     String?
  thumbnailUrl    String?           @map("thumbnail_url")
  status          TemplateStatus    @default(DRAFT)
  lastPublishedAt DateTime?         @map("last_published_at")
  versions        TemplateVersion[]
  tags            TemplateTag[]
  createdById     String?           @map("created_by_id")
  createdBy       UserAccount?      @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@map("template")
}

model TemplateVersion {
  id            String         @id @default(cuid())
  templateId    String         @map("template_id")
  versionNumber Int            @map("version_number")
  notes         String?
  defaultInput  Json           @map("default_input")
  inputExample  Json?          @map("input_example")
  isCurrent     Boolean        @default(false) @map("is_current")
  isPublished   Boolean        @default(false) @map("is_published")
  publishedAt   DateTime?      @map("published_at")
  publishedById String?        @map("published_by_id")
  createdById   String?        @map("created_by_id")
  status        Boolean        @default(true)
  template      Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pages         TemplatePage[]
  createdBy     UserAccount?   @relation("TemplateVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  publishedBy   UserAccount?   @relation("TemplateVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@unique([templateId, versionNumber])
  @@index([templateId, isCurrent])
  @@index([templateId, isPublished])
  @@map("template_version")
}

model TemplatePage {
  id                  String             @id @default(cuid())
  templateVersionId   String             @map("template_version_id")
  pageNumber          Int                @map("page_number")
  designerJson        Json               @map("designer_json")
  pageFormat          TemplatePageFormat @default(A4) @map("page_format")
  pageOrientation     PageOrientation    @default(PORTRAIT) @map("page_orientation")
  pageWidthMm         Float              @default(210) @map("page_width_mm")
  pageHeightMm        Float              @default(297) @map("page_height_mm")
  paddingVerticalMm   Float              @default(12) @map("padding_vertical_mm")
  paddingHorizontalMm Float              @default(12) @map("padding_horizontal_mm")
  sourceMode          TemplateSourceMode @default(BLANK) @map("source_mode")
  baseFileName        String?            @map("base_file_name")
  baseFileUrl         String?            @map("base_file_url")
  previewImageUrl     String?            @map("preview_image_url")
  status              Boolean            @default(true)
  templateVersion     TemplateVersion    @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@unique([templateVersionId, pageNumber])
  @@index([templateVersionId])
  @@map("template_page")
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  status    Boolean       @default(true)
  templates TemplateTag[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("tag")
}

model TemplateTag {
  templateId String @map("template_id")
  tagId      String @map("tag_id")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateId, tagId])
  @@map("template_tag")
}

model AuditEvent {
  id              String         @id @default(cuid())
  actorId         String?        @map("actor_id")
  apiCredentialId String?        @map("api_credential_id")
  action          String
  entityType      String         @map("entity_type")
  entityId        String?        @map("entity_id")
  metadata        Json?
  actor           UserAccount?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  apiCredential   ApiCredential? @relation("AuditApiCredential", fields: [apiCredentialId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([actorId])
  @@index([apiCredentialId])
  @@index([entityType, entityId])
  @@map("audit_event")
}
